<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootChat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    tools:context=".fragment.ChatFragment">

    <!-- Chat Header -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/page_background"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivPartnerAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_mine_avatar"
            android:contentDescription="对方头像"
            android:padding="10dp"
            android:src="@drawable/ic_user"
            app:tint="@color/brand_primary_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPartnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCompanionDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💕 已相伴 0 天"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/divider_tint" />

                <TextView
                    android:id="@+id/tvPartnerMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😊 平静"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLastActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最后活跃：刚刚"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="1dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/divider_tint"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTodayDiary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日已写日记"
                    android:textColor="@color/brand_primary_dark"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatHeader">

        <LinearLayout
            android:id="@+id/layoutMessageList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_chat_input_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btnInputMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_chat_action_circle"
            android:gravity="center"
            android:text="语音"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_field"
            android:hint="输入消息..."
            android:maxLines="4"
            android:minHeight="46dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnHoldToSpeak"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_field"
            android:gravity="center"
            android:text="按住 说话"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/btnPhoto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chat_action_circle"
            android:clickable="true"
            android:contentDescription="发送照片"
            android:focusable="true"
            android:padding="9dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/btnAi"
            android:layout_width="44dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chat_ai_button"
            android:gravity="center"
            android:text="AI"
            android:textColor="@color/brand_primary_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="52dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chat_send_button"
            android:gravity="center"
            android:text="发送"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
