<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:background="@drawable/bg_card_surface"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDiaryItemDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2026.04.18"
            android:textColor="@color/text_tertiary"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="进入日记详情"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_hint" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="top"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_mine_avatar"
            android:contentDescription="我的头像"
            android:padding="12dp"
            android:src="@drawable/ic_user"
            app:tint="@color/brand_primary_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDiaryItemAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDiaryItemMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_diary_tag"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="心情：开心 🙂"
                    android:textColor="@color/brand_primary_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDiaryItemContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="今天我们聊了很久，感觉轻松了很多。"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layoutDiaryItemImagePanel"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="top"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_diary_photo_green"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivDiaryItemPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvDiaryItemImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_diary_photo_count"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="1 张图片"
                android:textColor="@color/white"
                android:textSize="11sp" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
