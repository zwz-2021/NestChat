<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="14:32"
        android:textColor="@color/text_hint"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="top"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivPartnerAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_chat_avatar_partner"
            android:contentDescription="对方头像"
            android:padding="8dp"
            android:src="@drawable/ic_user"
            app:tint="@color/text_secondary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_bubble_left"
                android:maxWidth="240dp"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:text="今天过得怎么样？"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/ivMessageImage"
                android:layout_width="168dp"
                android:layout_height="132dp"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_chat_image_frame_left"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
