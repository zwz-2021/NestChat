<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    tools:context=".fragment.DiaryFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_diary_overview_card"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTodayStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="暂未绑定关系"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWeeklyCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="当前没有可展示的共享日记"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvDiaryHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="绑定后可查看双方日记和 TA 的情绪趋势"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📔"
                        android:textSize="44sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardDiaryEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDiaryEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前没有可展示的日记"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDiaryEmptySubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="建立绑定关系后，这里会展示你们的共同记录。"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMineDiaryList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/cardPartnerDiary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_surface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPartnerDiaryTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TA 的最新日记"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPartnerDiaryDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="暂无最新记录"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPartnerDiaryMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_diary_tag"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="等待第一篇日记"
                    android:textColor="@color/brand_primary_dark"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPartnerDiaryContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="当对方写下新的日记，这里会显示最近一篇。"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <FrameLayout
                    android:id="@+id/layoutPartnerDiaryImagePanel"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_diary_photo_yellow"
                    android:padding="8dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ivPartnerDiaryPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvPartnerDiaryImageCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_diary_photo_count"
                        android:paddingStart="8dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="4dp"
                        android:text="1 张图片"
                        android:textColor="@color/white"
                        android:textSize="11sp" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardTrend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTrendSectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TA 最近 7 天情绪趋势"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTrendHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="趋势严格按数据库中的日记记录渲染。"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTrendEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="暂未绑定关系，无法查看 TA 的情绪趋势。"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/layoutTrendPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_diary_chart_panel"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/layoutTrendBars"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:gravity="bottom"
                        android:minHeight="92dp"
                        android:orientation="horizontal" />

                    <LinearLayout
                        android:id="@+id/layoutTrendDates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabWriteDiary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="22dp"
        android:contentDescription="写日记"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/brand_primary"
        app:borderWidth="0dp"
        app:elevation="4dp"
        app:maxImageSize="24dp"
        app:tint="@color/white" />
</FrameLayout>
